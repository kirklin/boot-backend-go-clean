# Application settings
COMPOSE_PROJECT_NAME=boot
APP_ENVIRONMENT=development
SERVER_PORT=8888
GATEWAY_PORT=8888
REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_PER_MINUTE=200

# Database settings
DB_TYPE=postgres
# In Docker Compose network, use service name 'postgres' as host
DB_HOST=postgres
DB_PORT=5432
DB_EXPOSED_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME="${COMPOSE_PROJECT_NAME}_db"
DB_SSL_MODE=disable

# JWT settings
ACCESS_TOKEN_LIFETIME_HOURS=1
REFRESH_TOKEN_LIFETIME_HOURS=168
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret
JWT_ISSUER=your_application_name

# Snowflake settings
SNOWFLAKE_EPOCH=2026-01-01T00:00:00Z
SNOWFLAKE_MACHINE_BITS=10
SNOWFLAKE_STEP_BITS=12

