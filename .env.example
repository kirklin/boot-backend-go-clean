# Application settings
APP_ENVIRONMENT=development
APP_PORT=8888
REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_PER_MINUTE=200

# Database settings
DATABASE_TYPE=postgres
# 在 Docker Compose 网络中，使用服务名 'postgres' 作为主机名
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=myapp
DATABASE_SSL_MODE=disable

# JWT settings
ACCESS_TOKEN_LIFETIME_HOURS=1
REFRESH_TOKEN_LIFETIME_HOURS=168
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret
JWT_ISSUER=your_application_name

# Snowflake settings
SNOWFLAKE_EPOCH=2026-01-01T00:00:00Z
SNOWFLAKE_MACHINE_BITS=10
SNOWFLAKE_STEP_BITS=12

