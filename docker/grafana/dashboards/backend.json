{
  "title": "Boot Backend Services",
  "tags": ["go", "gin"],
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 38,
  "panels": [
    {
      "type": "timeseries",
      "title": "Total QPS",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "QPS"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Status Codes",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P99 Latency (Seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "P99 Latency"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Go Goroutines",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "go_goroutines",
          "legendFormat": "Goroutines"
        }
      ]
    }
  ]
}
