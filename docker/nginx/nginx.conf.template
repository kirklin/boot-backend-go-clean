server {
    listen       ${GATEWAY_PORT};
    listen  [::]:${GATEWAY_PORT};
    server_name _;

    # Ensure upstream Content-Type is preserved
    # (Nginx defaults to text/plain without mime.types)
    default_type application/octet-stream;

    # Redirect all HTTP requests to HTTPS
    # Uncomment the following lines if you have SSL certificates
    # return 301 https://$host$request_uri;

    # If no SSL, directly serve here
    location / {
        proxy_pass http://api:${SERVER_PORT};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;

        # Preserve upstream Content-Type (fixes HTML docs pages showing as text/plain)
        proxy_pass_header Content-Type;
        
        # Security Headers
        add_header X-Frame-Options "SAMEORIGIN";
        add_header X-XSS-Protection "1; mode=block";
        add_header X-Content-Type-Options "nosniff";
    }
}

